{
  "name": "cf-influencer-matching-engine",
  "version": "0.1.0",
  "description": "CatchFire Creator Matching Engine - AI-powered influencer discovery and matching based on craft storytelling skills",
  "main": "src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node src/index.js",
    "dev": "node src/index.js",
    "test": "node tests/test_vertex.js",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && gcloud run deploy cf-matching-engine --source . --region us-central1 --project catchfire-app-2026 --allow-unauthenticated",
    "match": "node src/index.js --match",
    "import": "node src/index.js --import"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.1.0",
    "@google-cloud/storage": "^7.18.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@google/genai": "^1.38.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^166.0.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Absolute-Space-GHCP/cf-influencer-matching-engine"
  },
  "author": "CatchFire / Johannes Leonardo",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
