{
  "displayName": "CatchFire: High Latency (p99 > 10s)",
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "Cloud Run request latency p99",
      "conditionThreshold": {
        "filter": "resource.type = \"cloud_run_revision\" AND resource.labels.service_name = \"cf-matching-engine\" AND metric.type = \"run.googleapis.com/request_latencies\"",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_PERCENTILE_99"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 10000,
        "duration": "300s",
        "trigger": { "count": 1 }
      }
    }
  ],
  "notificationChannels": [
    "projects/catchfire-app-2026/notificationChannels/14498102877036729188"
  ],
  "alertStrategy": {
    "autoClose": "604800s"
  }
}
