# CatchFire Influencer Matching Engine - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Google Cloud Platform
# =============================================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# =============================================================================
# Gemini AI Model
# =============================================================================
GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# Firestore Database
# =============================================================================
FIRESTORE_COLLECTION=creators

# =============================================================================
# Server Configuration
# =============================================================================
PORT=8090
BASE_URL=http://localhost:8090

# =============================================================================
# Security (helmet, cors, rate-limit)
# =============================================================================
# CORS_ORIGIN=true
# Set to a specific origin or comma-separated list in production (e.g. https://app.catchfire.com)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100

# =============================================================================
# App Identity
# =============================================================================
APP_NAME=CatchFire Matching Engine
APP_VERSION=0.1.0
ORG_NAME=CF - Influencer Matching Engine
SUPPORT_EMAIL=

# =============================================================================
# Optional: Google Sheets (for testing feedback — thumbs up/down → monitored sheet)
# =============================================================================
# FEEDBACK_SHEET_ID=your-sheet-id
# FEEDBACK_TAB_NAME=Feedback
# Sheet needs Sheets API write access (ADC or service account with spreadsheets scope).

# =============================================================================
# Optional: Analytics
# =============================================================================
ENABLE_ANALYTICS=true
