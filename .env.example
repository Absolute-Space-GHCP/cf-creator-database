# CatchFire Influencer Matching Engine - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Google Cloud Platform
# =============================================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# =============================================================================
# Gemini AI Model
# =============================================================================
GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# Firestore Database
# =============================================================================
FIRESTORE_COLLECTION=creators

# =============================================================================
# Server Configuration
# =============================================================================
PORT=8090
BASE_URL=http://localhost:8090

# =============================================================================
# App Identity
# =============================================================================
APP_NAME=CatchFire Matching Engine
APP_VERSION=0.1.0
ORG_NAME=CatchFire / Johannes Leonardo
SUPPORT_EMAIL=support@johannesleonardo.com

# =============================================================================
# Optional: Google Sheets (for feedback/logging)
# =============================================================================
# FEEDBACK_SHEET_ID=your-sheet-id
# FEEDBACK_TAB_NAME=Feedback

# =============================================================================
# Optional: Analytics
# =============================================================================
ENABLE_ANALYTICS=true
